# Copy to .env and adjust. NEVER commit .env. Consumed by docker-compose + service settings.

# --- General ---
ENV=development
LOG_LEVEL=info

# --- Web (Vite, must be prefixed VITE_) ---
VITE_API_BASE_URL=http://localhost:8000

# --- MongoDB ---
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=fpg

# --- Redis (cache + Arq job queue) ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=fpg
MINIO_ROOT_PASSWORD=fpg_dev_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=fpg-artifacts
S3_ACCESS_KEY=fpg
S3_SECRET_KEY=fpg_dev_password

# --- Qdrant (vector DB for building-code RAG, Phase 07) ---
QDRANT_URL=http://qdrant:6333

# --- Auth (Phase 03) ---
JWT_SECRET=change_me_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30

# --- OpenAI (rule extraction in Phase 07; deterministic fallback used when empty) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Internal service URLs (api -> services) ---
GENERATOR_URL=http://generator:8000
CODES_URL=http://codes:8000
VALIDATOR_URL=http://validator:8000
GEOMETRY_URL=http://geometry:8000
EXPORT_URL=http://export:8000
