        "op": "cmp",
        "metric": "room.min_dimension_mm",
        "comparator": ">=",
        "value": 1500
      },
      "severity": "warning",
      "citation": {
        "doc": "Generic IBC",
        "section": "1109.2",
        "text": "The minimum clear interior dimension of an accessible bathroom shall be not less than 1500 mm to accommodate a wheelchair turning space."
      }
    },
    {
