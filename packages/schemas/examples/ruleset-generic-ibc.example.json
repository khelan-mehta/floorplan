      "category": "stair_geometry",
      "applies_to": { "element": "stair" },
      "predicate": { "op": "cmp", "metric": "stair.run_mm", "comparator": ">=", "value": 280 },
      "severity": "error",
      "citation": {
        "doc": "Generic IBC",
        "section": "1011.5.2",
        "text": "Stair tread depth (run) shall be not less than 280 mm. Stair riser height shall be not more than 178 mm."
