      "category": "door_width",
      "applies_to": { "element": "door" },
      "predicate": {
        "op": "cmp",
        "metric": "door.clear_width_mm",
        "comparator": ">=",
        "value": 815
      },
      "severity": "error",
      "citation": {
        "doc": "Generic IBC",
        "section": "1010.1.1",
        "text": "The minimum clear width of a door opening serving as a component of a means of egress shall be not less than 815 mm."
      }
    },
    {
      "id": "egress-reachable",
      "category": "egress",
      "applies_to": { "element": "room" },
      "predicate": { "op": "cmp", "metric": "egress.reachable", "comparator": "==", "value": 1 },
