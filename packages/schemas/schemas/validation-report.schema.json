{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validation-report.schema.json",
  "title": "ValidationReport",
  "description": "Per-plan code-compliance result produced by the validator (Phase 09).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "ruleset_id", "score", "results"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "plan_id": { "$ref": "common.schema.json#/$defs/Uuid" },
    "ruleset_id": { "type": "string", "minLength": 1 },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "category_scores": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "results": {
      "type": "array",
      "items": { "$ref": "validation-report.schema.json#/$defs/RuleResult" }
    }
  },
  "$defs": {
    "RuleResult": {
      "title": "RuleResult",
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "status", "severity"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pass", "fail", "na"] },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "message": { "type": "string" },
        "geometry_ref": { "type": "string" },
        "fix_hint": { "type": "string" }
      }
    }
  }
}
